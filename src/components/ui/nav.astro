---
// Site-wide sticky navigation — rendered by BaseLayout on every page.
// Active state detection uses Astro.url.pathname (server-side, no JS needed).

const currentPath = Astro.url.pathname

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}

const navLinks = [
  { href: '/blog',        label: 'Blog' },
  { href: '/videos',      label: 'Videos' },
  { href: '/free-guides', label: 'Free Guides' },
  { href: '/resources',   label: 'Resources' },
  { href: '/about',       label: 'About' },
  { href: '/contact',     label: 'Contact' },
]
---

<header>
  <nav
    class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-[0_1px_3px_rgba(0,0,0,0.06)]"
    aria-label="Site navigation"
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Wordmark -->
        <a href="/" class="wordmark-link flex items-center gap-2.5 no-underline group" aria-label="Cash Dollars Online – home">
          <div
            class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 transition-transform duration-200 group-hover:scale-110"
            style="background-color:#2E7D32"
            aria-hidden="true"
          >
            <span class="font-black text-base text-white leading-none select-none">$</span>
          </div>
          <span class="font-bold text-gray-900 text-sm sm:text-[15px] leading-tight tracking-tight">
            Cash Dollars Online
          </span>
        </a>

        <!-- Desktop links -->
        <nav class="hidden md:flex items-center gap-0.5" aria-label="Main links">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150 no-underline',
                isActive(href) ? 'nav-link--active' : '',
              ]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>

        <!-- Desktop CTA + mobile toggle -->
        <div class="flex items-center gap-2">
          <a
            href="/free-guides"
            class="cta-pill hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-semibold no-underline transition-opacity duration-150 hover:opacity-90"
            aria-label="Get the free starter guide"
          >
            Free Guide
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>

          <button
            id="mobile-menu-toggle"
            type="button"
            class="md:hidden p-2 rounded-md text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-colors"
            aria-controls="mobile-menu"
            aria-expanded="false"
            aria-label="Toggle navigation menu"
          >
            <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>
    </div>

    <!-- Mobile dropdown -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-white border-t border-gray-100"
      role="navigation"
      aria-label="Mobile navigation"
    >
      <div class="px-4 py-3 space-y-0.5">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'mobile-nav-link flex items-center px-3 py-3 rounded-md text-sm font-medium transition-colors duration-150 no-underline',
              isActive(href) ? 'mobile-nav-link--active' : '',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
        <div class="pt-2 border-t border-gray-100 mt-1">
          <a
            href="/free-guides"
            class="flex items-center justify-center gap-2 py-3 rounded-full text-sm font-semibold no-underline"
            style="background-color:#FBC02D;color:#111827"
          >
            Get Free Guide
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Active link — brand green tint */
  .nav-link {
    color: #4b5563; /* gray-600 */
  }
  .nav-link:hover {
    color: #111827;
    background-color: #f9fafb;
  }
  .nav-link--active {
    color: #2E7D32 !important;
    background-color: #f0fdf4 !important;
    font-weight: 600;
  }

  /* Mobile links */
  .mobile-nav-link {
    color: #374151; /* gray-700 */
  }
  .mobile-nav-link:hover {
    color: #111827;
    background-color: #f9fafb;
  }
  .mobile-nav-link--active {
    color: #2E7D32 !important;
    background-color: #f0fdf4 !important;
    font-weight: 600;
  }

  /* Wordmark — suppress global link underline */
  .wordmark-link {
    text-decoration: none !important;
  }
  .wordmark-link:hover {
    color: inherit;
  }

  /* CTA pill */
  .cta-pill {
    background-color: #FBC02D;
    color: #111827;
    text-decoration: none !important;
  }
</style>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement | null
  const menu   = document.getElementById('mobile-menu')        as HTMLElement | null
  const ham    = document.getElementById('hamburger-icon')     as SVGElement  | null
  const x      = document.getElementById('close-icon')         as SVGElement  | null

  toggle?.addEventListener('click', () => {
    const opening = menu?.classList.contains('hidden') ?? true
    menu?.classList.toggle('hidden', !opening)
    toggle.setAttribute('aria-expanded', String(opening))
    ham?.classList.toggle('hidden', opening)
    x?.classList.toggle('hidden', !opening)
  })

  // Close when a link is tapped
  menu?.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      toggle?.setAttribute('aria-expanded', 'false')
      ham?.classList.remove('hidden')
      x?.classList.add('hidden')
    })
  )
</script>
