---
// Video library — /videos
// Required features per CLAUDE.md §5.5:
//   - Pulls from YouTube channel feed (YouTube Data API v3)
//   - Organized by series: Foundation / Affiliate Marketing / Digital Products
//   - Search/filter by topic
//   - Each card: thumbnail, title, length, "Watch on YouTube" CTA
//   - Goal is to grow the channel — link out, don't try to keep them on-site
//
// Schema: VideoObject per video (see CLAUDE.md §9)
// Data: getLatestVideos() from src/lib/youtube.ts

import BaseLayout from '../layouts/BaseLayout.astro'
// import { getLatestVideos } from '../lib/youtube'

