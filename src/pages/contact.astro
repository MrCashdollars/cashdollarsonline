---
// Contact — /contact
// Required features per CLAUDE.md §5.8:
//   - Simple form: name, email, message
//   - Honest response-time expectation
//   - Optional: links to social profiles

import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Contact"
  description="[DRAFT] Get in touch with Cash Dollars Online. I read every email and respond within 3–5 business days."
>
  <div class="container-content section-padding">
    <div class="max-w-lg mx-auto">
      <h1 class="text-3xl font-bold mb-4">Get in Touch</h1>
      <p class="text-gray-600 mb-8">
        [DRAFT] I read every email. Response time is typically 3–5 business days — I'm a one-person
        operation. For quick questions, the YouTube comments section often gets a faster reply.
      </p>

      <!-- TODO: wire to a form service (Netlify Forms, Formspree, or custom API endpoint) -->
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-green-800"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1"
            >Email address</label
          >
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-green-800"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-green-800 resize-y"
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">Send Message</button>
      </form>

      <div class="mt-12 pt-8 border-t border-gray-100">
        <p class="text-sm text-gray-500 mb-4">Also find us on:</p>
        <a
          href="https://youtube.com/@cashdollarsonline2195"
          class="text-sm text-brand-green-800 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          YouTube →
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
