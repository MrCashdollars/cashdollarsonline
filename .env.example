# ============================================================
# Cash Dollars Online — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is in .gitignore.
# ============================================================

# ------------------------------------------------------------
# YouTube Data API v3
# Get a key at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the Google Cloud console.
# ------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# WordPress REST API
# No auth key needed for public posts.
# Update if the WP install moves domains.
# ------------------------------------------------------------
WORDPRESS_API_URL=https://cashdollarsonline.com/wp-json/wp/v2

# ------------------------------------------------------------
# SendFox — email capture forms
# API key found at: https://sendfox.com/account/settings
# List ID found in SendFox > Lists > your list
# ------------------------------------------------------------
SENDFOX_API_KEY=your_sendfox_api_key_here
SENDFOX_LIST_ID=your_list_id_here

# ------------------------------------------------------------
# Plausible Analytics (privacy-friendly, GDPR-safe)
# Set to your domain once confirmed with user.
# Leave blank to disable analytics entirely.
# ------------------------------------------------------------
PLAUSIBLE_DOMAIN=cashdollarsonline.com
PLAUSIBLE_API_HOST=https://plausible.io

# ------------------------------------------------------------
# Site config (used for canonical URLs + sitemap)
# ------------------------------------------------------------
PUBLIC_SITE_URL=https://cashdollarsonline.com

# ------------------------------------------------------------
# Anthropic API key — AI chat / assistant feature
# Get yours at: https://console.anthropic.com
# Never commit your real key. Add the real value to .env.local (gitignored).
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
